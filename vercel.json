{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/*.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/google-ai/:path*", "destination": "/api/google-ai" },
    { "source": "/api/vertex-key/:path*", "destination": "/api/vertex-key" },
    { "source": "/api/gommo/:path*", "destination": "/api/gommo" }
  ]
}
